{
    "type": "library",
    "name": "locomotivemtl/charcoal-contrib-embed",
    "description": "Charcoal service provider for the Embed library.",
    "keywords": [
        "charcoal"
    ],
    "homepage": "https://github.com/locomotivemtl/charcoal-contrib-embed/",
    "license": "MIT",
    "authors": [
        {
            "name": "Locomotive",
            "homepage": "https://locomotive.ca"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "branch-alias": {
            "dev-master": "0.3.x-dev"
        }
    },
    "require": {
        "php": "^7.4 || ^8.0",
        "embed/embed": "^4.0",
        "guzzlehttp/psr7": "^2.11",
        "locomotivemtl/charcoal-app": "~0.8",
        "locomotivemtl/charcoal-property": "~0.8",
        "pimple/pimple": "^3.5",
        "psr/log": "^1.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "squizlabs/php_codesniffer": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Charcoal\\": "src/Charcoal/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Charcoal\\Tests\\": "tests/Charcoal/"
        }
    },
    "scripts": {
        "test": [
            "@tests"
        ],
        "tests": [
            "@phplint",
            "@phpcs",
            "@phpunit"
        ],
        "phplint": "find {src,tests} -name '*.php' -print0 | xargs -0 -n1 -P8 php -l | grep -v '^No syntax errors detected'; test $? -eq 1",
        "phpcs": "php vendor/bin/phpcs -ps --colors src/ tests/",
        "phpcbf": "php vendor/bin/phpcbf -ps --colors src/ tests/",
        "phpunit": "php vendor/bin/phpunit --coverage-text"
    },
    "config": {
        "sort-packages": true
    }
}
